<Project>
  <!-- Same as SelfContainedSingleFile but ReadyToRun-precompiled: methods are
       AOT-compiled to native code at publish time instead of JITted on first
       call, which noticeably cuts cold-start time at the cost of a larger
       exe (~15-20% bigger) and a slower publish step. Best choice if startup
       latency matters more than download size.
       Publish: dotnet publish src\WordBombGui\WordBombGui.csproj -c Release -p:PublishProfile=SelfContainedR2R -->
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <PublishDir>..\..\dist\gui-r2r\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishReadyToRun>true</PublishReadyToRun>
  </PropertyGroup>
</Project>
