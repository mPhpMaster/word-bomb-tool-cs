<Project>
  <!-- Small download (~1-5MB) that relies on the .NET 8 Desktop Runtime
       already being installed on the target machine (winget install
       Microsoft.DotNet.DesktopRuntime.8, or the app store/installer from
       https://dotnet.microsoft.com/download/dotnet/8.0). Not used by the
       installer by default since it adds a prerequisite-install step, but
       useful for machines that already have .NET 8 (e.g. developer boxes)
       where the 154MB self-contained download is wasteful.
       Publish: dotnet publish src\WordBombGui\WordBombGui.csproj -c Release -p:PublishProfile=FrameworkDependent -->
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <PublishDir>..\..\dist\gui-framework-dependent\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>
