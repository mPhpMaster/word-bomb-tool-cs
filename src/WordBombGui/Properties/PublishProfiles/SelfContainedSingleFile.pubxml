<Project>
  <!-- The default distributable: a single self-contained exe (~154MB) that
       needs nothing preinstalled on the target machine, no ReadyToRun
       precompilation (smaller than the R2R variant, slightly slower first
       JIT). This is what the installer bundles by default.
       Publish: dotnet publish src\WordBombGui\WordBombGui.csproj -c Release -p:PublishProfile=SelfContainedSingleFile -->
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <PublishDir>..\..\dist\gui-selfcontained\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>
