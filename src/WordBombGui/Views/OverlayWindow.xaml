<Window x:Class="WordBombTool.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Focusable="False"
        Visibility="Hidden">
    <Rectangle x:Name="BorderRect" Stroke="#61afef" StrokeThickness="2" Fill="Transparent" IsHitTestVisible="False"/>
</Window>
