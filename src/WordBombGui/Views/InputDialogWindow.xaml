<Window x:Class="WordBombTool.Views.InputDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="440" Height="200"
        MinWidth="420" MinHeight="180"
        SizeToContent="Height"
        Background="#282c34"
        FontFamily="Consolas" FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="14">
        <TextBlock x:Name="PromptText" Foreground="#abb2bf" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <TextBox x:Name="ValueBox" Background="#21252b" Foreground="#abb2bf"
                 BorderBrush="#3e4452" BorderThickness="1" Padding="4"
                 KeyDown="OnValueBoxKeyDown"/>
        <TextBlock x:Name="ErrorText" Foreground="#e06c75" Margin="0,6,0,0" Visibility="Collapsed"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="OkButton" Content="OK" Width="80" Height="28" Margin="0,0,8,0" Click="OnOkClick"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="28" Click="OnCancelClick" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
