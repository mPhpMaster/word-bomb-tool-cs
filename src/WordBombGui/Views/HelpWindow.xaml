<Window x:Class="WordBombTool.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help &amp; Hotkeys"
        Width="560" Height="520"
        MinWidth="520" MinHeight="470"
        Background="#282c34"
        FontFamily="Consolas" FontSize="13"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="8">
        <Button x:Name="CloseButton" Content="Close" DockPanel.Dock="Bottom"
                Width="90" Height="28" Margin="0,8,0,0" HorizontalAlignment="Right"
                Click="OnCloseClick" IsDefault="True" IsCancel="True"/>
        <TextBox x:Name="HelpText" IsReadOnly="True" TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 Background="#21252b" Foreground="#abb2bf" BorderThickness="1" BorderBrush="#3e4452"
                 Padding="6"/>
    </DockPanel>
</Window>
